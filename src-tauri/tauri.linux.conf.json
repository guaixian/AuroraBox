{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "identifier": "com.guaixian.aurorabox",
  "productName": "AuroraBox",
  "app": {
    "windows": [
      {
        "devtools": false,
        "maximizable": true,
        "decorations": true,
        "resizable": true,
        "title": "AuroraBox",
        "width": 900,
        "height": 650,
        "minWidth": 371,
        "minHeight": 514
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "targets": [
      "deb",
      "rpm"
    ],
    "linux": {
      "deb": {
        "desktopTemplate": "resources/main.desktop",
        "files": {
          "/usr/lib/AuroraBox/aurorabox-tun-helper": "resources/linux/aurorabox-tun-helper",
          "/etc/polkit-1/rules.d/49-aurorabox.rules": "resources/linux/49-aurorabox.rules",
          "/usr/share/polkit-1/actions/com.guaixian.aurorabox.policy": "resources/linux/com.guaixian.aurorabox.policy"
        }
      },
      "rpm": {
        "desktopTemplate": "resources/main.desktop"
      }
    },
    "externalBin": [
      "binaries/sing-box"
    ]
  }
}