{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "identifier": "com.guaixian.aurorabox",
  "productName": "AuroraBox",
  "app": {
    "windows": [
      {
        "devtools": true,
        "maximizable": true,
        "decorations": true,
        "resizable": true,
        "title": "AuroraBox",
        "width": 900,
        "height": 650,
        "minWidth": 371,
        "minHeight": 514
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "targets": [
      "deb",
      "rpm"
    ],
    "linux": {
      "deb": {
        "desktopTemplate": "resources/main.desktop"
      },
      "rpm": {
        "desktopTemplate": "resources/main.desktop"
      }
    },
    "externalBin": [
      "binaries/sing-box"
    ]
  }
}